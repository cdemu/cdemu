#. Display status
#: ../src/main.c:303
msgid "Starting CDEmu daemon with following parameters:\n"
msgstr "Se pornește demonul CDEmu cu următorii parametri:\n"

#: ../src/main.c:305
#, c-format
msgid " - config file: %s (exists: %d)\n"
msgstr " - fișier de configurare: %s (există: %d)\n"

#: ../src/main.c:307
msgid " - config file: N/A\n"
msgstr " - fișier de configurare: Indisp.\n"

#: ../src/main.c:309
#, c-format
msgid " - num devices: %i\n"
msgstr " - număr dispozitive: %i\n"

#: ../src/main.c:310
#, c-format
msgid " - control device: %s\n"
msgstr " - dispozitiv de control: %s\n"

#: ../src/main.c:311
#, c-format
msgid " - audio driver: %s\n"
msgstr " - driver audio: %s\n"

#: ../src/main.c:312
#, c-format
msgid " - bus type: %s\n"
msgstr " - tip de magistrală: %s\n"

#: ../src/main.c:313
#, c-format
msgid " - default CDEmu debug mask: 0x%X\n"
msgstr " - mască implicită de depanare CDEmu: 0x%X\n"

#: ../src/main.c:314
#, c-format
msgid " - default libMirage debug mask: 0x%X\n"
msgstr " - mască implicită de depanare libMirage: 0x%X\n"

#: ../src/main.c:315
#, c-format
msgid " - enable system sleep handler: %d\n"
msgstr " - activează manipulantul pentru adormirea sistemului: %d\n"

#: ../src/main.c:324
#, c-format
msgid "Invalid bus argument '%s', using default bus!\n"
msgstr ""
"Argument eronat „%s” pentru magistrală, se folosește magistrala implicită!\n"

#: ../src/main.c:340
msgid ""
"WARNING: using CDEmu on system bus is deprecated and might lead to security "
"issues on multi-user systems! Consult the README file for more details.\n"
"\n"
msgstr ""
"ATENȚIE: folosirea CDEmu pe magistrala sistemului e învechită și poate cauza p"
"robleme de securitate pe sisteme cu utilizatori multipli! Consultați fișierul "
"README pentru detalii suplimentare.\n"

#: ../src/main.c:348
msgid "Failed to add signal handler for SIGTERM!\n"
msgstr "Adăugarea manipulantului de semnale pentru SIGTERM a eșuat!\n"

#: ../src/main.c:351
msgid "Failed to add signal handler for SIGINT!\n"
msgstr "Adăugarea manipulantului de semnale pentru SIGINT a eșuat!\n"

#: ../src/main.c:355
